# ============================================
# TrendWatchNow - Environment Variables
# ============================================
# Copy this to .env.local for local dev
# Add all of these to Vercel → Settings → Environment Variables

# ---- Supabase (Database) ----
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- AI (Groq) ----
GROQ_API_KEY=gsk_your_groq_api_key_here

# ---- Images (Pexels) ----
PEXELS_API_KEY=your_pexels_api_key_here

# ---- Admin Login ----
# Use your email address as the admin login email
ADMIN_EMAIL=your-email@example.com

# Generate this hash by running: npx bcryptjs hash YourPassword123!
# Or use https://bcrypt-generator.com (use 10 rounds)
ADMIN_PASSWORD_HASH=$2a$10$your_bcrypt_hash_here

# ---- JWT Secret (any random string) ----
JWT_SECRET=any-random-secret-string-at-least-32-chars-long

# ---- Cron Secret (any random string) ----
CRON_SECRET=any-random-cron-secret-string

# ---- Site URL (for sitemap generation) ----
SITE_URL=https://trendwatchnow.com

# ---- Frontend Flag ----
# Set to "true" to connect frontend to API backend
VITE_HAS_BACKEND=true

# ---- Google Analytics 4 (optional) ----
# Get your Measurement ID from: Google Analytics → Admin → Data Streams → Your Stream
# Starts with "G-" e.g. G-ABC123XYZ
VITE_GA_ID=G-XXXXXXXXXX
